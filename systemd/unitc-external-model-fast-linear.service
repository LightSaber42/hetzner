[Unit]
Description=UnitC external model executor (CBC fast_linear)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=%h/Coding/unitc/backend
EnvironmentFile=/srv/unitc-external-model/model.env
ExecStart=%h/.venvs/unitc-external-model/bin/python -m app.serve --host 127.0.0.1 --port 18002 --model-id fast_linear --model-label "Fast Linear (CBC)"
Restart=always
RestartSec=5

[Install]
WantedBy=default.target
